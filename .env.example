POSTGRES_USER=pch
POSTGRES_PASSWORD=change_me_strong_random
POSTGRES_DB=pchsystem
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
JWT_SECRET=change_me_strong_random
JWT_ACCESS_TTL_SECONDS=3600
JWT_REFRESH_TTL_SECONDS=604800
AUTH_TOKEN_TTL_SECONDS=600
AUTH_TOKEN_RATE_LIMIT_SECONDS=30
# 密码登录限频（/auth/login；bcrypt 慢哈希 + 双维度滑窗防爆破/撞库）。均有默认值，按负载调整
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
LOGIN_RATE_LIMIT_MAX_PER_IP=20         # 单 IP 窗口内总尝试上限（防撞库扫号）
LOGIN_RATE_LIMIT_MAX_PER_CREDENTIAL=5  # 单用户名窗口内尝试上限（防针对爆破）
MCDR_SERVICE_TOKEN=change_me_service_token
WEB_BASE_URL=http://localhost:5173
# web 可达性探测地址：后端探它上报 /info.web_online（供插件 !!PCH status 嗅探前端）。
# web_base_url 是面向玩家浏览器的地址（含 localhost），后端/插件在容器内探它会命中容器自身 → 误报不可达；
# 故由后端探 compose 服务名（http://web，同网络可靠）。compose 默认 http://web；空 = 不探（/info.web_online=null）
WEB_PROBE_URL=http://web

# 投影解析上传上限（POST /parsing/batch）。单文件字节上限 + 批量护栏；均有默认值，按需调整
LITEMATIC_MAX_UPLOAD_BYTES=52428800           # 单个 .litematic 上限（默认 50MB）
NBT_MAX_UPLOAD_BYTES=52428800                 # 单个 .nbt 上限（默认 50MB）
PARSING_BATCH_MAX_FILES=10                    # 单次批量最多文件数（默认 10）
PARSING_BATCH_TOTAL_MAX_BYTES=104857600       # 单次批量全部文件字节之和上限（默认 100MB）

# 前端 Web 服务（nginx 托管 Frontend/dist + 反代 /api 到 backend）。默认启用；注释或清空下行 → web 服务不启动
COMPOSE_PROFILES=web
# nginx 对外端口（容器内固定 80）。默认 5173：免 root + 对齐 WEB_BASE_URL 默认值，单机开箱即用
WEB_PORT=5173
# backend / postgres 宿主端口（容器内固定 8000/5432）。默认 8000/5433；与其它栈共存时改（如沙盒 8100/15433）
BACKEND_PORT=8000
PG_PORT=5433
# 前端镜像构建用 npm registry（留空用默认；国内可设 https://registry.npmmirror.com）
NPM_REGISTRY=

# 归档 markdown 落盘根目录（sheet 归档生成 .md）。docker 已硬编码 /app/archive；此处供宿主机直跑后端时用
ARCHIVE_ROOT=./Archive
# 可选：自定义静态片段目录（覆盖内置 header/footer 文案，留空只用内置）
MARKDOWN_FRAGMENTS_DIR=

# wiki 内容 git 仓（后端推归档，wiki.js 双向同步）。默认未配置 = 不推送。
WIKI_GIT_REMOTE_URL=
WIKI_GIT_BRANCH=main
WIKI_GIT_TOKEN=
WIKI_GIT_AUTHOR_NAME=PCHSystem
WIKI_GIT_AUTHOR_EMAIL=pchsystem@local
